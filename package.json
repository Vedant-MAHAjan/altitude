{
  "name": "trekking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:sync": "npm run db:generate && npm run db:push",
    "db:generate": "prisma generate",
    "db:push": "node scripts/require-database-url.mjs prisma db push",
    "snapshots:generate": "node scripts/require-database-url.mjs tsx src/lib/catalog/generate.ts",
    "scrape": "node scripts/require-database-url.mjs tsx src/scrapers/run.ts",
    "scrape:dry": "tsx src/scrapers/run.ts --dry-run",
    "test:scrapers": "tsx --test src/scrapers/**/*.test.ts",
    "verify:local": "npm run typecheck && npm run test:scrapers && npm run build",
    "sync:live": "npm run db:sync && npm run scrape"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
